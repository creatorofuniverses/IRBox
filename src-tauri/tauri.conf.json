{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IRBox",
  "version": "1.2.0",
  "identifier": "com.iran.irbox",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "IRBox",
        "width": 960,
        "height": 640,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["irbox"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "pcores/sing-box",
      "pcores/xray"
    ],
    "resources": {
      "pcores/geoip.dat": "geoip.dat",
      "pcores/geosite.dat": "geosite.dat"
    },
    "license": "GPL-3.0",
    "licenseFile": "../LICENSE",
    "publisher": "IranGuard",
    "windows": {
      "nsis": {
        "installerHooks": "nsis-m.nsi"
      }
    }
  }
}
